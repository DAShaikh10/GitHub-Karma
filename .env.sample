# GitHub GraphQL API Configurations.
GITHUB_GRAPHQL_API_URL = https://api.github.com/graphql
GITHUB_PERSONAL_ACCESS_TOKEN = # ADD YOUR GITHUB PERSONAL ACCESS TOKEN HERE.

# Application API Configurations.
CACHE_REVALIDATE_SECONDS = 3600 # 60 * 60 * 1 = 1 hour

# GitHub Karma Multipliers and Thresholds.
# Creator score curve (for stars and forks):
# score = scaleFactor * (plateau * (1 - exp(-count / saturationScale)) + tailSlope * count)
# - plateau: near-ceiling contribution of the saturating component
# - saturationScale: how quickly the curve approaches plateau (higher = slower)
# - tailSlope: linear growth added for high counts

STAR_PLATEAU_SCORE = # Star curve plateau contribution.
STAR_SATURATION_SCALE = # Star curve saturation speed control.
STAR_TAIL_SLOPE = # Extra linear star growth at high star counts.

FORK_PLATEAU_SCORE = # Fork curve plateau contribution.
FORK_SATURATION_SCALE = # Fork curve saturation speed control.
FORK_TAIL_SLOPE = # Extra linear fork growth at high fork counts.
FORK_CURVE_WEIGHT = # Global multiplier applied to fork curve score.

HIGH_IMPACT_REPO_THRESHOLD = # Minimum high-impact repos needed for legend boost.
HIGH_IMPACT_STARS = # Repo is high-impact if stars meet or exceed this value.
HIGH_IMPACT_FORKS = # Repo is high-impact if forks meet or exceed this value.
LEGEND_MULTIPLIER = # Multiplies total creator karma once threshold is met.

# Contributor karma is a weighted sum of activity counts.
COMMIT_WEIGHT = # Points per commit.
CONTRIBUTOR_PR_WEIGHT = # Points per pull request opened.
CONTRIBUTOR_REVIEW_WEIGHT = # Points per review submitted.
CONTRIBUTOR_ISSUE_WEIGHT = # Points per issue created.
CONTRIBUTOR_ANSWER_WEIGHT = # Points per discussion answer.
